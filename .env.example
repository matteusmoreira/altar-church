# Worker de webhooks outbound (POST /api/internal/integrations/dispatch)
INTEGRATION_WORKER_SECRET=
# Worker Kids dedicado (opcional; cron compartilhado usa INTEGRATION_WORKER_SECRET)
KIDS_WORKER_SECRET=
# Força HTTPS em URLs de webhook fora de development (default on; use 0 para desligar)
INTEGRATION_WEBHOOK_HTTPS_ONLY=1
# Kids: chave AES-256 (64 hex ou base64 de 32 bytes) para detalhes de saúde.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KIDS_HEALTH_ENCRYPTION_KEY=
# Kids: pepper do hash de PIN de retirada (opcional; deriva da chave de saúde se vazio)
KIDS_PIN_PEPPER=
