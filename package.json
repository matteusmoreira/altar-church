{
  "name": "altar-church",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs && npm run test:volunteers:v2",
    "test:volunteers:v2": "node --experimental-strip-types --test tests/volunteer-scheduler.test.ts",
    "e2e:setup": "node scripts/ensure-e2e-users.mjs",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "integrations:verify": "node scripts/verify-integrations.mjs",
    "integrations:dispatch": "node scripts/dispatch-integrations.mjs",
    "integrations:echo": "node scripts/webhook-echo-server.mjs",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/apply-pending-migrations.mjs",
    "db:audit": "node --env-file-if-exists=.env.local scripts/audit-database.mjs",
    "db:optimize": "node --env-file-if-exists=.env.local scripts/optimize-database.mjs",
    "kids:configure-pin": "node scripts/configure-kids-pin-pepper.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@types/web-push": "^3.6.4",
    "@zxing/browser": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "fabric": "^7.4.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "qz-tray": "^2.2.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.1",
    "resend": "^6.17.2",
    "shadcn": "^4.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
